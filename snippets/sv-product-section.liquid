{% assign sv_show_search  = sv_show_search  | default: false %}
{% assign sv_search_query = sv_search_query | default: ''    %}

<section class="sv-collection-wrapper">

  {%- comment -%} ── FILTER SIDEBAR ── {%- endcomment -%}
  <aside class="sv-filter-panel">


{% unless sv_show_search %} 
    {%- comment -%} Product Type / Category {%- endcomment -%}
    <accordion-tab open>
      <h3 data-header class="sv-filter-header">
        Product Type
        <span class="sv-toggle-icon">−</span>
      </h3>
      <div data-content class="sv-filter-body">
        <div class="sv-search-wrap">
          <input
            type="text"
            class="sv-category-search"
            placeholder="Find a category"
            aria-label="Search categories">
          <span class="sv-search-icon">
            <img src="{{ 'search.svg' | asset_url }}" alt="" width="14" height="14">
          </span>
        </div>
        <div class="sv-category-list">
          <ul class="sv-checkbox-list">
            {% for col in collections %}
              <li>
                <label>
                  <input
                    type="checkbox"
                    class="sv-filter-check"
                    data-filter-group="category"
                    value="{{ col.handle }}">
                  <span>{{ col.title }}</span>
                </label>
              </li>
            {% endfor %}
          </ul>
        </div>
        {% if collections.size > 6 %}
          <button class="sv-show-more-btn" id="sv-show-more-cat">
            + {{ collections.size | minus: 6 }} More
          </button>
        {% endif %}
      </div>
    </accordion-tab>
{% endunless %}


   {%- comment -%} Update the Price Accordion Tab [cite: 8, 9, 10] {%- endcomment -%}
    <accordion-tab open>
      <h3 data-header class="sv-filter-header">Price <span class="sv-toggle-icon">−</span></h3>
      <div data-content class="sv-filter-body">
        <div class="sv-price-slider-wrap">
          <div class="sv-price-track">
            <div class="sv-price-fill" id="sv-price-fill"></div>
            <div class="sv-price-thumb sv-price-thumb--left" id="sv-thumb-min"></div>
            <div class="sv-price-thumb sv-price-thumb--right" id="sv-thumb-max"></div>
          </div>
        </div>
        <div class="sv-price-inputs">
          <div class="sv-price-field">
            <span>$</span>
            <input type="text" id="sv-price-min" value="{{ min_price_cents | divided_by: 100.0 | floor }}" aria-label="Min">
          </div>
          <span class="sv-price-sep">To</span>
          <div class="sv-price-field">
            <span>$</span>
            <input type="text" id="sv-price-max" value="{{ max_price_cents | divided_by: 100.0 | ceil }}" aria-label="Max">
          </div>
        </div>
      </div>
    </accordion-tab>

    {%- comment -%} Product status {%- endcomment -%}
    <accordion-tab open>
      <h3 data-header class="sv-filter-header">
        Product Status
        <span class="sv-toggle-icon">−</span>
      </h3>
      <div data-content class="sv-filter-body">
        <ul class="sv-checkbox-list">
          <li>
            <label>
              <input type="checkbox" class="sv-filter-check" data-filter-group="status" value="in_stock">
              In stock
            </label>
          </li>
          <li>
            <label>
              <input type="checkbox" class="sv-filter-check" data-filter-group="status" value="out_stock">
              Out of Stock
            </label>
          </li>
          <li>
            <label>
              <input type="checkbox" class="sv-filter-check" data-filter-group="status" value="on_sale">
              On sale
            </label>
          </li>
        </ul>
      </div>
    </accordion-tab>

    {%- comment -%} Size & Color accordion-tabs are injected by collection.js {%- endcomment -%}
    <button class="sv-reset-btn" id="sv-reset-filters">Reset filters</button>

  </aside>

  {%- comment -%} ── PRODUCTS SECTION ── {%- endcomment -%}
  <div class="sv-products-section">

    {%- comment -%} ── Search bar (search page only) ── {%- endcomment -%}
    {% if sv_show_search %}
      <div class="sv-product-search-wrap">
        <form
          action="{{ routes.search_url }}"
          method="get"
          class="sv-product-search-form"
          role="search">
          {%- comment -%} Restrict Shopify search to products only {%- endcomment -%}
          <input type="hidden" name="type" value="product">
         {%- comment -%} Locate the sv-product-search-field div and update it as follows: {%- endcomment -%}
<div class="sv-product-search-field">
  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#888" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="11" cy="11" r="8"/>
    <line x1="21" y1="21" x2="16.65" y2="16.65"/>
  </svg>
  <input
    type="search"
    name="q"
    id="sv-product-search"
    value="{{ sv_search_query | escape }}"
    placeholder="Search products…"
    aria-label="Search products"
    autocomplete="off"
    role="combobox"
    aria-expanded="false"
    aria-owns="predictive-search-results"
    aria-controls="predictive-search-results"
    aria-haspopup="listbox"
    aria-autocomplete="list"
  >
  {%- comment -%} ADD THIS CONTAINER FOR LIVE PREDICTIVE RESULTS {%- endcomment -%}
  <div id="predictive-search-results" tabindex="-1" class="sv-predictive-search-container"></div>
  
  {% if sv_search_query != '' %}
    <button type="button" class="sv-search-clear-btn" id="sv-search-clear" aria-label="Clear search">✕</button>
  {% endif %}
</div>
          <button type="submit" class="sv-search-submit-btn">Search</button>
        </form>
      </div>
    {% endif %}

    {%- comment -%} ── Active filter chips ── {%- endcomment -%}
    <div class="sv-active-filters" id="sv-active-filters"></div>

    {%- comment -%} ── Toolbar: sort, view, per-page ── {%- endcomment -%}
    <div class="sv-toolbar">
      <div class="sv-toolbar-left">

        {%- comment -%} Custom sort dropdown {%- endcomment -%}
        <div class="sv-custom-select-wrapper">
          <select
            class="sv-sort-select"
            id="sv-sort-select"
            aria-label="Sort products"
            style="display:none;">
            <option value="">Featured</option>
            <option value="best-selling">Best Selling</option>
            <option value="alpha-asc">Alphabetically, A–Z</option>
            <option value="alpha-desc">Alphabetically, Z–A</option>
            <option value="price-asc">Price, low to high</option>
            <option value="price-desc">Price, high to low</option>
            <option value="date-desc">Date, new to old</option>
            <option value="date-asc">Date, old to new</option>
          </select>
          <div class="sv-custom-select">
            <div class="sv-custom-select-trigger">
              <span>Default Sorting</span>
              <svg width="14" height="8" viewBox="0 0 14 8" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M1 1L7 7L13 1" stroke="#68778D" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="sv-custom-options">
              <span class="sv-custom-option" data-value="">Featured</span>
              <span class="sv-custom-option" data-value="best-selling">Best Selling</span>
              <span class="sv-custom-option" data-value="alpha-asc">Alphabetically, A–Z</span>
              <span class="sv-custom-option" data-value="alpha-desc">Alphabetically, Z–A</span>
              <span class="sv-custom-option" data-value="price-asc">Price, low to high</span>
              <span class="sv-custom-option" data-value="price-desc">Price, high to low</span>
              <span class="sv-custom-option" data-value="date-desc">Date, new to old</span>
              <span class="sv-custom-option" data-value="date-asc">Date, old to new</span>
            </div>
          </div>
        </div>

        <div class="sv-view-switcher" role="group" aria-label="Grid layout">
          <button class="sv-view-btn" data-sv-grid="sv-grid-list" aria-label="List view">
            <img src="{{ 'list.svg' | asset_url }}" alt="List">
          </button>
          <button class="sv-view-btn" data-sv-grid="sv-grid-2" aria-label="2 columns">
            <img src="{{ '2col.svg' | asset_url }}" alt="2 columns">
          </button>
          <button class="sv-view-btn sv-hide-mobile" data-sv-grid="sv-grid-3" aria-label="3 columns">
            <img src="{{ '3col.svg' | asset_url }}" alt="3 columns">
          </button>
          <button class="sv-view-btn sv-active sv-hide-mobile" data-sv-grid="sv-grid-4" aria-label="4 columns">
            <img src="{{ '4col.svg' | asset_url }}" alt="4 columns">
          </button>
        </div>

      </div>

      <div class="sv-toolbar-right">
        <span>Show</span>
      {%- comment -%} Update Pagination Select  {%- endcomment -%}
<select class="sv-per-page-select" id="sv-per-page">
  <option value="8" selected>8</option>
  <option value="12">12</option>
  <option value="24">24</option>
</select>
      </div>
    </div>

    <script id="sv-all-products-data" type="application/json">
      [{%- for product in sv_products -%}
        {%- assign size_idx  = nil -%}
        {%- assign color_idx = nil -%}
        {%- for opt in product.options -%}
          {%- assign opt_down = opt | downcase -%}
          {%- if opt_down == 'size' -%}
            {%- assign size_idx = forloop.index0 -%}
          {%- endif -%}
          {%- if opt_down == 'color' or opt_down == 'colour' -%}
            {%- assign color_idx = forloop.index0 -%}
          {%- endif -%}
        {%- endfor -%}
        {
          "id":               {{ product.id }},
          "title":            {{ product.title | json }},
          "handle":           {{ product.handle | json }},
          "url":              {{ product.url | json }},
          "price":            {{ product.price | divided_by: 100.0 }},
          "compare_at_price": {{ product.compare_at_price | default: 0 | divided_by: 100.0 }},
          "available":        {{ product.available }},
          "on_sale":          {% if product.compare_at_price > product.price %}true{% else %}false{% endif %},
          "published_at":     {{ product.published_at | date: "%s" | plus: 0 }},
          "image":            {% if product.featured_image %}"{{ product.featured_image | image_url: width: 300 }}"{% else %}null{% endif %},
          "collections":      [{% for c in product.collections %}"{{ c.handle }}"{% unless forloop.last %},{% endunless %}{% endfor %}],
          "sizes":            [{%- if size_idx != nil -%}{%- for variant in product.variants -%}"{{ variant.options[size_idx] | downcase }}"{% unless forloop.last %},{% endunless %}{%- endfor -%}{%- endif -%}],
          "colors":           [{%- if color_idx != nil -%}{%- for variant in product.variants -%}"{{ variant.options[color_idx] | downcase }}"{% unless forloop.last %},{% endunless %}{%- endfor -%}{%- endif -%}],
          "type":             {{ product.type | downcase | json }},
          "tags":             {{ product.tags | json }}
        }{% unless forloop.last %},{% endunless %}
      {%- endfor -%}]
    </script>

    {%- comment -%} ── Server-rendered initial 12 cards (replaced by JS immediately) ── {%- endcomment -%}
    <div class="sv-product-grid sv-grid-4" id="sv-product-grid">
      {%- for product in sv_products limit: 12 -%}
        <div class="sv-product-card" data-product-id="{{ product.id }}">
          <a href="{{ product.url }}" class="sv-card-link">
            <div class="sv-card-image">
              {% if product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 300 }}"
                  alt="{{ product.title | escape }}"
                  loading="lazy"
                  width="300"
                  height="300">
              {% endif %}
            </div>
            <div class="sv-card-info">
              <div class="sv-card-info-main">
                <h4 class="sv-card-title">{{ product.title }}</h4>
                <div class="sv-card-price">
                  {{ product.price | money }}
                  {% if product.compare_at_price > product.price %}
                    <span class="sv-price-original">{{ product.compare_at_price | money }}</span>
                  {% endif %}
                </div>
              </div>
              <div class="sv-card-rating">
                <svg width="12" height="12" viewBox="0 0 12 12" fill="#f5a623">
                  <path d="M6 1l1.5 3h3l-2.4 1.8.9 3L6 7.2 3 8.8l.9-3L1.5 4h3z"/>
                </svg>
                4.5 (189)
              </div>
            </div>
          </a>
        </div>
      {%- endfor -%}
    </div>

    {%- comment -%} ── Load more / progress ── {%- endcomment -%}
    {%  render 'show-more' current_product_count: current_product_count, total_product_count: total_product_count %} 
  </div>
</section>