{{ 'header-popup.css' |  asset_url |  stylesheet_tag }}

<!-- ── Search Modal Overlay ── -->
<div class="sv-modal-overlay" id="sv-modal-overlay" role="dialog" aria-modal="true" aria-label="Search">
  <div class="sv-modal" id="sv-modal">

    <div class="sv-modal__header">
      <div class="sv-modal__input-wrap">
        <span class="sv-modal__search-icon">
          {{ 'search-header.svg' | inline_asset_content }}
        </span>
        <input
          type="text"
          id="sv-search-input"
          class="sv-search-input"
          placeholder="Search products &amp; collections…"
          autocomplete="off"
          aria-label="Search"
          aria-autocomplete="list"
          aria-haspopup="listbox" />
        <button
          class="sv-modal__clear"
          id="sv-search-close"
          aria-label="Clear search">&#x2715;</button>
      </div>
      <button class="sv-modal__close" id="sv-modal-close" aria-label="Close search">&#x2715;</button>
    </div>

    <div class="sv-modal__body">
      <div
        class="sv-search-dropdown"
        id="sv-search-dropdown"
        role="listbox"></div>

      <div class="sv-modal__empty-state" id="sv-empty-state">
        <div class="sv-modal__empty-icon">🔍</div>
        <p class="sv-modal__empty-title">Start typing to search</p>
        <p class="sv-modal__empty-sub">Find products, collections and more</p>
      </div>
    </div>

  </div>
</div>

<header>
  <h2 class="header__title">
    {{ shop.name | link_to: routes.root_url }}
  </h2>

  <div class="header__menu">
    {% for link in section.settings.menu.links %}
      <a href="{{ link.url }}">{{ link.title }}</a>
    {% endfor %}
  </div>

  <div class="header__icons">

    <div class="sv-search-container" id="sv-search-container">
      <button
        class="sv-search-icon"
        id="sv-search-icon"
        aria-label="Open search">
        {{ 'search-header.svg' | inline_asset_content }}
      </button>
    </div>

    {% if shop.customer_accounts_enabled %}
      <shopify-account menu="{{ section.settings.customer_account_menu }}">
        {{ 'icon-account.svg' | inline_asset_content }}
      </shopify-account>
    {% endif %}

    <a href="{{ routes.cart_url }}">
      {% if cart.item_count > 0 %}
        <sup>{{ cart.item_count }}</sup>
      {% endif %}
      {{ 'icon-cart.svg' | inline_asset_content }}
    </a>

  </div>
</header>

<script>
(function () {

  /* ── Money format ── */
  const MONEY_FORMAT = {{ shop.money_format | json }};

  function formatMoney(cents) {
    if (!cents && cents !== 0) return '';
    const symbol = MONEY_FORMAT
      .replace(/\{\{.*?\}\}/, '').trim()
      .replace(/[0-9.,\s]/g, '').trim() || '$';
    return symbol + (cents / 100).toFixed(2);
  }

  /* ── DOM refs ── */
  const openBtn     = document.getElementById('sv-search-icon');
  const overlay     = document.getElementById('sv-modal-overlay');
  const modal       = document.getElementById('sv-modal');
  const closeBtn    = document.getElementById('sv-modal-close');
  const clearBtn    = document.getElementById('sv-search-close');
  const input       = document.getElementById('sv-search-input');
  const dropdown    = document.getElementById('sv-search-dropdown');
  const emptyState  = document.getElementById('sv-empty-state');

  let debounceTimer = null;
  let currentFocus  = -1;
  let lastQuery     = '';
  const cache       = {};

  /* ── Open modal ── */
  function openModal() {
    overlay.classList.add('sv-modal--open');
    document.body.style.overflow = 'hidden';
    requestAnimationFrame(() => input.focus());
  }

  /* ── Close modal ── */
  function closeModal() {
    overlay.classList.remove('sv-modal--open');
    document.body.style.overflow = '';
    closeDropdown();
    input.value = '';
    clearBtn.classList.remove('sv-visible');
    lastQuery = '';
    showEmptyState(true);
  }

  /* ── Close dropdown only ── */
  function closeDropdown() {
    dropdown.classList.remove('sv-open');
    dropdown.innerHTML = '';
    currentFocus = -1;
    dropdown._cards = [];
  }

  /* ── Empty state toggle ── */
  function showEmptyState(show) {
    emptyState.style.display = show ? 'flex' : 'none';
  }

  /* ── Event listeners ── */
  openBtn.addEventListener('click', openModal);
  closeBtn.addEventListener('click', closeModal);

  clearBtn.addEventListener('click', () => {
    input.value = '';
    clearBtn.classList.remove('sv-visible');
    closeDropdown();
    showEmptyState(true);
    lastQuery = '';
    input.focus();
  });

  /* Close when clicking the dim backdrop */
  overlay.addEventListener('click', e => {
    if (e.target === overlay) closeModal();
  });

  /* Show/hide clear × */
  input.addEventListener('input', () => {
    clearBtn.classList.toggle('sv-visible', input.value.length > 0);
  });

  /* ── Shimmer skeleton ── */
  function showShimmer(count = 4) {
    dropdown.innerHTML = '';
    for (let i = 0; i < count; i++) {
      dropdown.innerHTML += `
        <div class="sv-shimmer-card">
          <div class="sv-shimmer-img"></div>
          <div class="sv-shimmer-body">
            <div class="sv-shimmer-line"></div>
            <div class="sv-shimmer-line sv-shimmer-line--short"></div>
          </div>
        </div>`;
    }
    dropdown.classList.add('sv-open');
    showEmptyState(false);
  }

  /* ── Fetch with cache ── */
  async function fetchSuggestions(q) {
    if (cache[q]) return cache[q];
    const url = `/search/suggest.json?q=${encodeURIComponent(q)}`
      + `&resources[type]=product,collection`
      + `&resources[limit]=6`;
    const res = await fetch(url);
    if (!res.ok) throw new Error(`Search API error ${res.status}`);
    const data = await res.json();
    cache[q] = data;
    return data;
  }

  /* ── Render results ── */
  function renderResults(data, query) {
    dropdown.innerHTML = '';
    currentFocus = -1;

    const results     = data?.resources?.results ?? {};
    const products    = results.products    ?? [];
    const collections = results.collections ?? [];

    if (!products.length && !collections.length) {
      dropdown.innerHTML = `<p class="sv-search-status">No results for "<strong>${escHtml(query)}</strong>"</p>`;
      dropdown.classList.add('sv-open');
      showEmptyState(false);
      return;
    }

    const allCards = [];

    if (products.length) {
      dropdown.appendChild(sectionTitle('Products'));
      products.forEach(p => {
        const priceStr = p.price
          ? formatMoney(p.price)
          : (p.price_min ? formatMoney(p.price_min) : '');
        const imgSrc = p.image?.url
          || (typeof p.featured_image === 'string' ? p.featured_image : p.featured_image?.url)
          || '';
        const card = buildCard({ title: p.title, sub: priceStr, imgSrc, badge: null, url: p.url });
        dropdown.appendChild(card);
        allCards.push(card);
      });
    }

    if (collections.length) {
      if (products.length) dropdown.appendChild(divider());
      dropdown.appendChild(sectionTitle('Collections'));
      collections.forEach(c => {
        const imgSrc = c.image?.url
          || (typeof c.featured_image === 'string' ? c.featured_image : c.featured_image?.url)
          || '';
        const card = buildCard({
          title: c.title,
          sub: c.products_count != null ? `${c.products_count} products` : '',
          imgSrc,
          badge: 'Collection',
          url: c.url
        });
        dropdown.appendChild(card);
        allCards.push(card);
      });
    }

    const viewAll = document.createElement('a');
    viewAll.className = 'sv-view-all';
    viewAll.textContent = `View all results for "${query}"`;
    viewAll.href = `/search?q=${encodeURIComponent(query)}&type=product,article,page`;
    viewAll.addEventListener('click', e => { e.preventDefault(); window.location.href = viewAll.href; });
    dropdown.appendChild(viewAll);

    dropdown.classList.add('sv-open');
    dropdown._cards = allCards;
    showEmptyState(false);
  }

  /* ── Build card ── */
  function buildCard({ title, sub, imgSrc, badge, url }) {
    const card = document.createElement('div');
    card.className = 'sv-result-card';
    card.setAttribute('role', 'option');
    card.tabIndex = -1;

    const imgHtml = imgSrc
      ? `<img class="sv-result-card__img" src="${escAttr(imgSrc)}" alt="${escAttr(title)}" loading="lazy" />`
      : `<div class="sv-result-card__img-placeholder">🛍</div>`;

    const badgeHtml = badge
      ? `<span class="sv-result-card__badge">${escHtml(badge)}</span>`
      : '';

    card.innerHTML = `
      ${imgHtml}
      <div class="sv-result-card__body">
        <div class="sv-result-card__title">${escHtml(title)}</div>
        ${sub ? `<div class="sv-result-card__sub">${escHtml(sub)}</div>` : ''}
      </div>
      ${badgeHtml}`;

    card.addEventListener('click', () => { window.location.href = url; });
    card.addEventListener('mouseenter', () => {
      (dropdown._cards || []).forEach(c => c.classList.remove('sv-focused'));
      card.classList.add('sv-focused');
    });
    card.addEventListener('mouseleave', () => card.classList.remove('sv-focused'));
    return card;
  }

  /* ── Keyboard nav ── */
  function setFocus(index) {
    const cards = dropdown._cards || [];
    cards.forEach(c => c.classList.remove('sv-focused'));
    currentFocus = index;
    if (index >= 0 && cards[index]) {
      cards[index].classList.add('sv-focused');
      cards[index].scrollIntoView({ block: 'nearest' });
    }
  }

  input.addEventListener('keydown', e => {
    const cards = dropdown._cards || [];
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      setFocus(Math.min(currentFocus + 1, cards.length - 1));
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      setFocus(Math.max(currentFocus - 1, 0));
    } else if (e.key === 'Enter') {
      if (currentFocus >= 0 && cards[currentFocus]) {
        cards[currentFocus].click();
      } else if (input.value.trim()) {
        window.location.href = `/search?q=${encodeURIComponent(input.value.trim())}&type=product,article,page`;
      }
    } else if (e.key === 'Escape') {
      closeModal();
    }
  });

  /* ── Debounced input ── */
  input.addEventListener('input', () => {
    const q = input.value.trim();
    if (!q) { closeDropdown(); showEmptyState(true); return; }
    if (q === lastQuery) return;
    lastQuery = q;

    showShimmer(4);
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(async () => {
      try {
        const data = await fetchSuggestions(q);
        if (input.value.trim() === q) renderResults(data, q);
      } catch (err) {
        console.error('[sv-search]', err);
        dropdown.innerHTML = '<p class="sv-search-status">Something went wrong. Please try again.</p>';
        dropdown.classList.add('sv-open');
        showEmptyState(false);
      }
    }, 160);
  });

  /* ── XSS helpers ── */
  function escHtml(str) {
    return String(str)
      .replace(/&/g, '&amp;').replace(/</g, '&lt;')
      .replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }
  function escAttr(str) { return escHtml(str); }

  /* ── DOM helpers ── */
  function sectionTitle(text) {
    const p = document.createElement('p');
    p.className = 'sv-dropdown-section-title';
    p.textContent = text;
    return p;
  }
  function divider() {
    const d = document.createElement('div');
    d.className = 'sv-dropdown-divider';
    return d;
  }

})();
</script>

{% schema %}
  {
    "name": "header popup",
    "settings": [
      {
        "type": "link_list",
        "id": "menu",
        "label": "t:labels.menu"
      }, {
        "type": "link_list",
        "id": "customer_account_menu",
        "label": "t:labels.customer_account_menu",
        "default": "customer-account-main-menu"
      }
    ],
    "presets": [{"name" : "header-popup"}]
  }
{% endschema %}
