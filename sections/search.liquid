{{ 'collection.css' | asset_url | stylesheet_tag }}

{% comment %} Restrict Shopify search to products only {% endcomment %}
{% assign sv_search_products = search.results | where: 'object_type', 'product' %}

<div class="sv-search-page-header">
  {% if search.performed %}
    {% if sv_search_products.size > 0 %}
      <h1 class="sv-page-title">
        Results for
        <em>&ldquo;{{ search.terms | escape }}&rdquo;</em>
      </h1>
      <p class="sv-search-meta">
        {{ sv_search_products.size }}
        product{% if sv_search_products.size != 1 %}s{% endif %}
        found
      </p>
    {% else %}
      <h1 class="sv-page-title">No results for &ldquo;{{ search.terms | escape }}&rdquo;</h1>
      <p class="sv-search-meta">Try a different keyword or browse the filters below.</p>
    {% endif %}
  {% else %}
    <h1 class="sv-page-title">Search</h1>
  {% endif %}
</div>

{% render 'sv-product-section'
  ,
 sv_products: sv_search_products
  ,
 sv_show_search: true
  ,
 sv_search_query: search.terms
%}

<script src="{{ 'collection.js' | asset_url }}" defer="defer"></script>

{% schema %}
  {
    "name": "Search results",
    "settings": []
  }
{% endschema %}
