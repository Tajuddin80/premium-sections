{% comment %}
  Live predictive search section.
  Calls /search/suggest.json on input (debounced 300ms).
  Shows products + collections in card view below the search bar.
  Falls back to normal form submit on Enter / button click.
{% endcomment %}

<div class="search-page">
  <h1 class="search-page__title">{{ 'search.title' | t }}</h1>

  <div class="search-bar-wrapper">
    <form action="{{ routes.search_url }}" method="get" role="search" class="search-form">
      <div class="search-input-group">
        <svg class="search-input-group__icon" aria-hidden="true" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <input
          id="search-input"
          type="search"
          name="q"
          autocomplete="off"
          spellcheck="false"
          value="{{ search.terms | escape }}"
          placeholder="{{ 'search.placeholder' | t }}"
          aria-label="{{ 'search.placeholder' | t }}"
          aria-autocomplete="list"
          aria-controls="live-search-results"
          aria-expanded="false"
        >
        <button type="button" id="search-clear" class="search-clear" aria-label="Clear search" hidden>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
        </button>
      </div>
      <button type="submit" class="search-submit">{{ 'search.submit' | t }}</button>
    </form>

    <!-- Live results dropdown -->
    <div id="live-search-results" class="live-results" role="listbox" hidden>
      <div id="live-results-inner"></div>
    </div>
  </div>

  <!-- Static (server-rendered) results — hidden while live search is active -->
  <div id="static-results">
    {% if search.performed %}
      {% if search.results_count == 0 %}
        <p class="search-feedback">{{ 'search.no_results_html' | t: terms: search.terms }}</p>
      {% else %}
        <p class="search-feedback">{{ 'search.results_for_html' | t: terms: search.terms, count: search.results_count }}</p>

        <div class="search-results">
          {% paginate search.results by 20 %}
            {% for result in search.results %}
              <a class="search-card" href="{{ result.url }}">
                {% assign featured_image = result.featured_image | default: result.image %}
                {% if featured_image %}
                  <div class="search-card__media">
                    {{ featured_image | image_url: width: 400 | image_tag: class: 'search-card__img', alt: featured_image.alt | escape }}
                  </div>
                {% else %}
                  <div class="search-card__media search-card__media--placeholder">
                    <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="m9 15 3-3 3 3"/><circle cx="8.5" cy="8.5" r="1.5"/></svg>
                  </div>
                {% endif %}
                <div class="search-card__body">
                  <p class="search-card__title">{{ result.title }}</p>
                  {% if result.price %}
                    <p class="search-card__price">{{ result.price | money_with_currency }}</p>
                  {% endif %}
                </div>
              </a>
            {% endfor %}
            <div class="search-results__pagination">
              {{ paginate | default_pagination }}
            </div>
          {% endpaginate %}
        </div>
      {% endif %}
    {% endif %}
  </div>
</div>

{% stylesheet %}
  *,
  *::before,
  *::after { box-sizing: border-box; }

  .search-page {
    max-width: 900px;
    margin: 0 auto;
    padding: 2rem 1.25rem 4rem;
  }

  .search-page__title {
    margin: 0 0 1.5rem;
    font-size: 1.75rem;
    font-weight: 600;
  }

  /* ── Search bar ─────────────────────────────────── */
  .search-bar-wrapper {
    position: relative;
  }

  .search-form {
    display: flex;
    gap: .625rem;
  }

  .search-input-group {
    position: relative;
    flex: 1;
    display: flex;
    align-items: center;
  }

  .search-input-group__icon {
    position: absolute;
    left: .875rem;
    color: #888;
    pointer-events: none;
    flex-shrink: 0;
  }

  #search-input {
    width: 100%;
    height: 48px;
    padding: 0 2.75rem 0 2.75rem;
    font-size: 1rem;
    border: 1.5px solid #d0d0d0;
    border-radius: 10px;
    outline: none;
    background: #fff;
    transition: border-color .15s;
    -webkit-appearance: none;
  }

  #search-input:focus {
    border-color: #111;
  }

  /* remove native 'X' in Chrome/Edge */
  #search-input::-webkit-search-cancel-button { display: none; }

  .search-clear {
    position: absolute;
    right: .75rem;
    background: none;
    border: none;
    cursor: pointer;
    color: #888;
    display: flex;
    align-items: center;
    padding: 4px;
    border-radius: 4px;
  }

  .search-clear:hover { color: #111; }

  .search-submit {
    height: 48px;
    padding: 0 1.25rem;
    font-size: .9375rem;
    font-weight: 500;
    background: #111;
    color: #fff;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    white-space: nowrap;
    transition: opacity .15s;
    flex-shrink: 0;
  }

  .search-submit:hover { opacity: .82; }

  /* ── Live results panel ──────────────────────────── */
  .live-results {
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    right: 0;
    background: #fff;
    border: 1.5px solid #e0e0e0;
    border-radius: 12px;
    box-shadow: 0 8px 32px rgba(0,0,0,.10), 0 2px 8px rgba(0,0,0,.06);
    z-index: 999;
    overflow: hidden;
    max-height: 75vh;
    overflow-y: auto;
  }

  /* ── Section heading inside panel ───────────────── */
  .live-section-heading {
    padding: .625rem 1rem .25rem;
    font-size: .6875rem;
    font-weight: 600;
    letter-spacing: .07em;
    text-transform: uppercase;
    color: #888;
  }

  /* ── Cards grid ──────────────────────────────────── */
  .live-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: .75rem;
    padding: .5rem 1rem 1rem;
  }

  .live-card {
    display: flex;
    flex-direction: column;
    border-radius: 10px;
    border: 1.5px solid #f0f0f0;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
    transition: border-color .15s, box-shadow .15s, transform .1s;
    background: #fafafa;
    outline: none;
  }

  .live-card:hover,
  .live-card[aria-selected="true"] {
    border-color: #bbb;
    box-shadow: 0 4px 14px rgba(0,0,0,.08);
    transform: translateY(-2px);
  }

  .live-card__media {
    aspect-ratio: 1/1;
    overflow: hidden;
    background: #f2f2f2;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .live-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .live-card__placeholder {
    color: #ccc;
  }

  .live-card__body {
    padding: .5rem .625rem .625rem;
    display: flex;
    flex-direction: column;
    gap: .2rem;
  }

  .live-card__title {
    font-size: .8125rem;
    font-weight: 500;
    line-height: 1.35;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    overflow: hidden;
    margin: 0;
  }

  .live-card__price {
    font-size: .75rem;
    color: #555;
    margin: 0;
  }

  .live-card__badge {
    display: inline-block;
    font-size: .6875rem;
    font-weight: 500;
    background: #f0f0f0;
    color: #444;
    border-radius: 4px;
    padding: 1px 6px;
    margin-top: 2px;
  }

  /* ── "View all" footer link ──────────────────────── */
  .live-view-all {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: .75rem 1rem;
    border-top: 1px solid #f0f0f0;
    font-size: .875rem;
    color: #111;
    text-decoration: none;
    font-weight: 500;
    cursor: pointer;
  }

  .live-view-all:hover { background: #fafafa; }

  .live-view-all svg { flex-shrink: 0; }

  /* ── Skeleton loading ────────────────────────────── */
  .skeleton-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: .75rem;
    padding: .5rem 1rem 1rem;
  }

  .skeleton-card {
    border-radius: 10px;
    overflow: hidden;
    border: 1.5px solid #f0f0f0;
    background: #fafafa;
  }

  .skeleton-img {
    aspect-ratio: 1/1;
    background: linear-gradient(90deg,#ececec 25%,#f5f5f5 50%,#ececec 75%);
    background-size: 200% 100%;
    animation: shimmer 1.4s infinite;
  }

  .skeleton-line {
    height: 12px;
    border-radius: 6px;
    margin: .625rem .625rem .3rem;
    background: linear-gradient(90deg,#ececec 25%,#f5f5f5 50%,#ececec 75%);
    background-size: 200% 100%;
    animation: shimmer 1.4s infinite;
  }

  .skeleton-line--short {
    width: 55%;
    height: 10px;
    margin-bottom: .75rem;
  }

  @keyframes shimmer {
    to { background-position: -200% 0; }
  }

  /* ── Empty state ─────────────────────────────────── */
  .live-empty {
    padding: 1.5rem 1rem;
    text-align: center;
    color: #888;
    font-size: .9375rem;
  }

  /* ── Static results (server-rendered) ───────────── */
  .search-feedback {
    color: #555;
    font-size: .9375rem;
    margin: 1.5rem 0 1rem;
  }

  .search-results {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1.25rem;
    margin-top: .5rem;
  }

  .search-card {
    display: flex;
    flex-direction: column;
    border-radius: 12px;
    border: 1.5px solid #ebebeb;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    background: #fafafa;
    transition: box-shadow .15s, transform .1s;
  }

  .search-card:hover {
    box-shadow: 0 6px 20px rgba(0,0,0,.08);
    transform: translateY(-2px);
  }

  .search-card__media {
    aspect-ratio: 1/1;
    overflow: hidden;
    background: #f2f2f2;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .search-card__media--placeholder { color: #ccc; }

  .search-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .search-card__body {
    padding: .75rem .875rem .875rem;
    display: flex;
    flex-direction: column;
    gap: .25rem;
  }

  .search-card__title {
    font-size: .875rem;
    font-weight: 500;
    line-height: 1.35;
    margin: 0;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    overflow: hidden;
  }

  .search-card__price {
    font-size: .8125rem;
    color: #555;
    margin: 0;
  }

  .search-results__pagination {
    grid-column: 1/-1;
    display: flex;
    gap: .5rem;
    justify-content: center;
    padding-top: .5rem;
    flex-wrap: wrap;
  }
{% endstylesheet %}

<script>
(function () {
  'use strict';

  const DEBOUNCE_MS = 300;
  const MIN_CHARS   = 2;
  const PRODUCT_LIMIT     = 8;
  const COLLECTION_LIMIT  = 4;

  const input       = document.getElementById('search-input');
  const clearBtn    = document.getElementById('search-clear');
  const panel       = document.getElementById('live-results');
  const inner       = document.getElementById('live-results-inner');
  const staticBlock = document.getElementById('static-results');

  let debounceTimer = null;
  let currentQuery  = '';
  let selectedIdx   = -1;
  let cards         = [];

  /* ── Helpers ──────────────────────────────────── */

  function openPanel()  { panel.hidden = false; input.setAttribute('aria-expanded', 'true');  }
  function closePanel() { panel.hidden = true;  input.setAttribute('aria-expanded', 'false'); selectedIdx = -1; cards = []; }

  function showStatic(show) {
    staticBlock.style.display = show ? '' : 'none';
  }

  function skeletonHTML(count = 4) {
    return `
      <div class="live-section-heading">Searching…</div>
      <div class="skeleton-grid">
        ${'<div class="skeleton-card"><div class="skeleton-img"></div><div class="skeleton-line"></div><div class="skeleton-line skeleton-line--short"></div></div>'.repeat(count)}
      </div>`;
  }

  function placeholderSVG() {
    return `<svg class="live-card__placeholder" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="m9 15 3-3 3 3"/><circle cx="8.5" cy="8.5" r="1.5"/></svg>`;
  }

  function moneyFormat(cents) {
    if (cents == null) return '';
    const amount = (cents / 100).toFixed(2);
    return window.Shopify?.currency?.active
      ? amount + ' ' + window.Shopify.currency.active
      : amount;
  }

  function cardHTML({ url, image, title, price, badge }) {
    const imgHTML = image
      ? `<img class="live-card__img" src="${image}" alt="${title.replace(/"/g, '&quot;')}" loading="lazy" width="200" height="200">`
      : placeholderSVG();

    return `
      <a class="live-card" href="${url}" role="option" aria-selected="false" tabindex="-1">
        <div class="live-card__media">${imgHTML}</div>
        <div class="live-card__body">
          <p class="live-card__title">${title}</p>
          ${price   ? `<p class="live-card__price">${price}</p>`   : ''}
          ${badge   ? `<span class="live-card__badge">${badge}</span>` : ''}
        </div>
      </a>`;
  }

  function renderResults(data, query) {
    const products    = (data.resources?.results?.products    || []).slice(0, PRODUCT_LIMIT);
    const collections = (data.resources?.results?.collections || []).slice(0, COLLECTION_LIMIT);

    if (!products.length && !collections.length) {
      inner.innerHTML = `<div class="live-empty">No results for <strong>${escapeHTML(query)}</strong></div>`;
      return;
    }

    let html = '';

    if (products.length) {
      html += `<p class="live-section-heading" aria-label="Products">Products</p>`;
      html += `<div class="live-grid">`;
      products.forEach(p => {
        const image = p.featured_image?.url
          ? p.featured_image.url.replace(/(\?.*)?$/, '?width=400')
          : null;
        html += cardHTML({
          url:   p.url,
          image,
          title: p.title,
          price: p.price ? moneyFormat(p.price) : null
        });
      });
      html += `</div>`;
    }

    if (collections.length) {
      html += `<p class="live-section-heading" aria-label="Collections">Collections</p>`;
      html += `<div class="live-grid">`;
      collections.forEach(c => {
        const image = c.featured_image?.url
          ? c.featured_image.url.replace(/(\?.*)?$/, '?width=400')
          : null;
        html += cardHTML({
          url:   c.url,
          image,
          title: c.title,
          badge: 'Collection'
        });
      });
      html += `</div>`;
    }

    const totalCount = products.length + collections.length;
    if (totalCount > 0) {
      html += `
        <a class="live-view-all" href="{{ routes.search_url }}?q=${encodeURIComponent(query)}&type=product">
          View all results for "${escapeHTML(query)}"
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>`;
    }

    inner.innerHTML = html;
    cards = Array.from(inner.querySelectorAll('.live-card'));
  }

  function escapeHTML(str) {
    return str.replace(/[&<>"']/g, s => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[s]));
  }

  /* ── Fetch ────────────────────────────────────── */

  async function fetchSuggestions(query) {
    const params = new URLSearchParams({
      q: query,
      'resources[type]':     'product,collection',
      'resources[limit]':    String(Math.max(PRODUCT_LIMIT, COLLECTION_LIMIT)),
      'resources[options][unavailable_products]': 'last',
      'resources[options][fields]': 'title,variants.title,body,vendor,product_type,tag,variants.sku'
    });

    const res = await fetch(`/search/suggest.json?${params}`, {
      headers: { 'Content-Type': 'application/json' }
    });

    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    return res.json();
  }

  /* ── Main search handler ──────────────────────── */

  async function doSearch(query) {
    query = query.trim();
    if (query === currentQuery) return;
    currentQuery = query;

    if (query.length < MIN_CHARS) {
      closePanel();
      showStatic(true);
      return;
    }

    inner.innerHTML = skeletonHTML();
    openPanel();
    showStatic(false);

    try {
      const data = await fetchSuggestions(query);
      if (query !== currentQuery) return; // stale
      renderResults(data, query);
    } catch (err) {
      console.error('[LiveSearch]', err);
      inner.innerHTML = `<div class="live-empty">Something went wrong. Please try again.</div>`;
    }
  }

  /* ── Keyboard navigation ──────────────────────── */

  function updateSelection(idx) {
    cards.forEach((c, i) => {
      const active = i === idx;
      c.setAttribute('aria-selected', active);
      if (active) c.classList.add('live-card--focused');
      else c.classList.remove('live-card--focused');
    });
  }

  input.addEventListener('keydown', e => {
    if (panel.hidden) return;

    if (e.key === 'ArrowDown') {
      e.preventDefault();
      selectedIdx = Math.min(selectedIdx + 1, cards.length - 1);
      updateSelection(selectedIdx);
    } else if (e.key === 'ArrowUp') {
      e.preventDefault();
      selectedIdx = Math.max(selectedIdx - 1, -1);
      updateSelection(selectedIdx);
      if (selectedIdx === -1) input.focus();
    } else if (e.key === 'Enter' && selectedIdx >= 0) {
      e.preventDefault();
      cards[selectedIdx]?.click();
    } else if (e.key === 'Escape') {
      closePanel();
      showStatic(true);
    }
  });

  /* ── Input events ─────────────────────────────── */

  input.addEventListener('input', () => {
    const val = input.value;
    clearBtn.hidden = !val;
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => doSearch(val), DEBOUNCE_MS);
    selectedIdx = -1;
  });

  clearBtn.addEventListener('click', () => {
    input.value = '';
    clearBtn.hidden = true;
    currentQuery = '';
    closePanel();
    showStatic(true);
    input.focus();
  });

  /* ── Close on outside click ───────────────────── */

  document.addEventListener('pointerdown', e => {
    if (!panel.contains(e.target) && e.target !== input && e.target !== clearBtn) {
      closePanel();
    }
  });

  /* ── Re-focus search input after page load with terms ── */

  if (input.value.length >= MIN_CHARS) {
    clearBtn.hidden = false;
  }

})();
</script>

{% schema %}
{
  "name": "t:general.search",
  "settings": []
}
{% endschema %}
