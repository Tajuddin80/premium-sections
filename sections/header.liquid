{{ 'header.css' | asset_url | stylesheet_tag }}

<header>
  <h2 class="header__title">
    {{ shop.name | link_to: routes.root_url }}
  </h2>

  <div class="header__menu">
    {% for link in section.settings.menu.links %}
      <a href="{{ link.url }}">{{ link.title }}</a>
    {% endfor %}
  </div>

  <div class="header__icons">
    {%- comment -%} 
      ADDED data-url and data-money-format for the JS class to consume 
    {%- endcomment -%}
    <div class="sv-search-container" 
         id="sv-search-container" 
         data-url="/search/suggest.json" 
         data-money-format='{{ shop.money_format | json | escape }}'>

      <button
        class="sv-search-icon"
        id="sv-search-icon"
        aria-label="Open search">
        {{ 'search-header.svg' | inline_asset_content }}
      </button>

      <div class="sv-search-input-wrapper" id="sv-search-wrapper">
        <input
          type="text"
          id="sv-search-input"
          class="sv-search-input"
          placeholder="Search products & collections…"
          autocomplete="off"
          aria-label="Search"
          aria-autocomplete="list"
          aria-haspopup="listbox" />
        <button
          class="sv-search-close"
          id="sv-search-close"
          aria-label="Clear search">&#x2715;</button>
      </div>

      <div
        class="sv-search-dropdown"
        id="sv-search-dropdown"
        role="listbox"></div>
    </div>

    {% if shop.customer_accounts_enabled %}
      <shopify-account menu="{{ section.settings.customer_account_menu }}">
        {{ 'icon-account.svg' | inline_asset_content }}
      </shopify-account>
    {% endif %}

    <a href="{{ routes.cart_url }}">
      {% if cart.item_count > 0 %}
        <sup>{{ cart.item_count }}</sup>
      {% endif %}
      {{ 'icon-cart.svg' | inline_asset_content }}
    </a>

  </div>
</header>

{%- comment -%} Include your new JavaScript file {%- endcomment -%}
<script src="{{ 'header-search.js' | asset_url }}" defer="defer"></script>

{% schema %}
  {
    "name": "t:general.header",
    "settings": [
      {
        "type": "link_list",
        "id": "menu",
        "label": "t:labels.menu"
      }, 
      {
        "type": "link_list",
        "id": "customer_account_menu",
        "label": "t:labels.customer_account_menu",
        "default": "customer-account-main-menu"
      }
    ],
    "presets": [{"name" : "header"}]
  }
{% endschema %}