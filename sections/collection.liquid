 TODO 1: hide 3 and 4 col grid icon on mobile screen 2: maximum amount should be set as i want. 3: {% endcomment %}

{{ 'collection.css' | asset_url | stylesheet_tag }}

<h1>{{ collection.title }}</h1>

<section class="sv-collection-wrapper">

  <aside class="sv-filter-panel">

    <accordion-tab open>
      <h3 data-header class="sv-filter-header">
        Product Type
        <span class="sv-toggle-icon">−</span>
      </h3>
      <div data-content class="sv-filter-body">
        <div class="sv-search-wrap">
          <input
            type="text"
            class="sv-category-search"
            placeholder="Find a category"
            aria-label="Search categories">
          <span class="sv-search-icon"><img src="{{ 'search.svg' | asset_url }}" alt="search icon"></span>
        </div>
        <ul class="sv-checkbox-list sv-category-list">
          {% for col in collections %}
            <li>
              <label>
                <input
                  type="checkbox"
                  class="sv-filter-check"
                  data-filter-group="category"
                  value="{{ col.handle }}">
                <span>{{ col.title }}</span>
              </label>
            </li>
          {% endfor %}
        </ul>
        {% assign hidden_count = collections.size | minus: 6 %}
        {% if hidden_count > 0 %}
          <button class="sv-show-more-btn" id="sv-show-more-cat">+ {{ hidden_count }} More</button>
        {% endif %}
      </div>
    </accordion-tab>

    <accordion-tab open>
      <h3 data-header class="sv-filter-header">
        Price
        <span class="sv-toggle-icon">−</span>
      </h3>
      <div data-content class="sv-filter-body">
        <div class="sv-price-slider-wrap">
          <div class="sv-price-track">
            <div class="sv-price-fill" id="sv-price-fill"></div>
            <div class="sv-price-thumb sv-price-thumb--left" id="sv-thumb-min"></div>
            <div class="sv-price-thumb sv-price-thumb--right" id="sv-thumb-max"></div>
          </div>
        </div>
        <div class="sv-price-inputs">
          <div class="sv-price-field">
            <span>$</span>
            <input
              type="text"
              id="sv-price-min"
              value="0"
              aria-label="Minimum price">
          </div>
          <span class="sv-price-sep">To</span>
          <div class="sv-price-field">
            <span>$</span>
            <input
              type="text"
              id="sv-price-max"
              value="3000"
              aria-label="Maximum price">
          </div>
        </div>
      </div>
    </accordion-tab>


    <accordion-tab open>
      <h3 data-header class="sv-filter-header">
        Product Status
        <span class="sv-toggle-icon">−</span>
      </h3>
      <div data-content class="sv-filter-body">
        <ul class="sv-checkbox-list">
          <li>
            <label><input
                type="checkbox"
                class="sv-filter-check"
                data-filter-group="status"
                value="in_stock"> In stock</label>
          </li>
          <li>
            <label><input
                type="checkbox"
                class="sv-filter-check"
                data-filter-group="status"
                value="out_stock"> Out of Stock</label>
          </li>
          <li>
            <label><input
                type="checkbox"
                class="sv-filter-check"
                data-filter-group="status"
                value="on_sale"> On sale</label>
          </li>
        </ul>
      </div>
    </accordion-tab>

    <button class="sv-reset-btn" id="sv-reset-filters">Reset filters</button>

  </aside>

  <div class="sv-products-section">

    <div class="sv-active-filters" id="sv-active-filters"></div>

    <div class="sv-toolbar">
      <div class="sv-toolbar-left">

        <div class="sv-custom-select-wrapper">
          <select
            class="sv-sort-select"
            id="sv-sort-select"
            aria-label="Sort products"
            style="display: none;">
            <option value="">Featured</option>
            <option value="best-selling">Best Selling</option>
            <option value="alpha-asc">Alphabetically, A-Z</option>
            <option value="alpha-desc">Alphabetically, Z-A</option>
            <option value="price-asc">Price, low to high</option>
            <option value="price-desc">Price, high to low</option>
            <option value="date-desc">Date, new to old</option>
            <option value="date-asc">Date, old to new</option>
          </select>

          <div class="sv-custom-select">
            <div class="sv-custom-select-trigger">
              <span>Default Sorting</span>
              <svg
                width="14"
                height="8"
                viewBox="0 0 14 8"
                fill="none"
                xmlns="http://www.w3.org/2000/svg">
                <path
                  d="M1 1L7 7L13 1"
                  stroke="#68778D"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round" />
              </svg>
            </div>
            <div class="sv-custom-options">
              <span class="sv-custom-option" data-value="">Featured</span>
              <span class="sv-custom-option" data-value="best-selling">Best Selling</span>
              <span class="sv-custom-option" data-value="alpha-asc">Alphabetically, A-Z</span>
              <span class="sv-custom-option" data-value="alpha-desc">Alphabetically, Z-A</span>
              <span class="sv-custom-option" data-value="price-asc">Price, low to high</span>
              <span class="sv-custom-option" data-value="price-desc">Price, high to low</span>
              <span class="sv-custom-option" data-value="date-desc">Date, new to old</span>
              <span class="sv-custom-option" data-value="date-asc">Date, old to new</span>
            </div>
          </div>
        </div>

        <div
          class="sv-view-switcher"
          role="group"
          aria-label="Grid layout">
          <button
            class="sv-view-btn"
            data-sv-grid="sv-grid-list"
            aria-label="List view">
            <img src="{{ 'list.svg' | asset_url }}" alt="List">
          </button>
          <button
            class="sv-view-btn"
            data-sv-grid="sv-grid-2"
            aria-label="2 columns">
            <img src="{{ '2col.svg' | asset_url }}" alt="2 columns">
          </button>
          <button
            class="sv-view-btn"
            data-sv-grid="sv-grid-3"
            aria-label="3 columns">
            <img src="{{ '3col.svg' | asset_url }}" alt="3 columns">
          </button>
          <button
            class="sv-view-btn sv-active"
            data-sv-grid="sv-grid-4"
            aria-label="4 columns">
            <img src="{{ '4col.svg' | asset_url }}" alt="4 columns">
          </button>
        </div>

      </div>

      <div class="sv-toolbar-right">
        <span>Show</span>
        <select
          class="sv-per-page-select"
          id="sv-per-page"
          aria-label="Products per page">
          <option value="12">12</option>
          <option value="24">24</option>
          <option value="48">48</option>
        </select>
      </div>
    </div>


    <script id="sv-all-products-data" type="application/json">
      [{%- for product in collections.all.products -%}{%- comment -%}
          Detect which option index holds Size and Color {%- endcomment -%}
        {%- assign size_idx  = nil -%}
        {%- assign color_idx = nil -%}
        {%- for opt in product.options -%}
          {%- assign opt_down = opt | downcase -%}
          {%- if opt_down == 'size' -%}
            {%- assign size_idx  = forloop.index0 -%}
            {%- endif -%} {%- if opt_down == 'color' or opt_down == 'colour' -%} {%- assign color_idx = forloop.index0 -%}
            {%- endif -%}
            {%- endfor -%}
            {
              "id": {{ product.id }},
              "title": {{ product.title | json }},
              "handle": {{ product.handle | json }},
              "url": {{ product.url | json }},
              "price": {{ product.price | divided_by: 100.0 }},
              "compare_at_price": {{ product.compare_at_price | default: 0 | divided_by: 100.0 }},
              "available": {{ product.available }},
              "on_sale": {% if product.compare_at_price > product.price %} true {% else %} false{% endif %},
            "published_at": {{ product.published_at | date: "%s" | plus: 0 }},
            "image": {% if product.featured_image %}"{{ product.featured_image | image_url: width: 300 }}"{% else %}null{% endif %},
          "collections": [{% for c in product.collections %}"{{ c.handle }}"{% unless forloop.last %},{% endunless %}{% endfor %}],
      "sizes": [{%- if size_idx != nil -%}{%- for variant in product.variants -%}
          "{{ variant.options[size_idx] | downcase }}"{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
        {%- endif -%}],
      "colors": [{%- if color_idx != nil -%}{%- for variant in product.variants -%}
          "{{ variant.options[color_idx] | downcase }}"{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
        {%- endif -%}],
      "type": {{ product.type | downcase | json }}
    }{% unless forloop.last %},{% endunless %}
  {%- endfor -%}]
    </script>


    <div class="sv-product-grid sv-grid-4" id="sv-product-grid">
      {%- for product in collections.all.products limit: 12 -%}
        <div
          class="sv-product-card"
          data-product-id="{{ product.id }}"
          data-price="{{ product.price | divided_by: 100.0 }}"
          data-available="{{ product.available }}"
          data-on-sale="{% if product.compare_at_price > product.price %}true{% else %}false{% endif %}">
          <a href="{{ product.url }}" class="sv-card-link">
            <div class="sv-card-image">
              {% if product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 300 }}"
                  alt="{{ product.title | escape }}"
                  loading="lazy"
                  width="300"
                  height="300">
              {% endif %}
            </div>
            <div class="sv-card-info">
              <div class="sv-card-info-main">
                <h4 class="sv-card-title">{{ product.title }}</h4>
                <div class="sv-card-price">
                  {{ product.price | money }}
                  {% if product.compare_at_price > product.price %}
                    <span class="sv-price-original">{{ product.compare_at_price | money }}</span>
                  {% endif %}
                </div>
              </div>
              <div class="sv-card-rating">
                <svg
                  width="12"
                  height="12"
                  viewBox="0 0 12 12"
                  fill="#f5a623"><path d="M6 1l1.5 3h3l-2.4 1.8.9 3L6 7.2 3 8.8l.9-3L1.5 4h3z" /></svg>
                4.5 (189)
              </div>
            </div>
          </a>
        </div>
      {%- endfor -%}
    </div>

    <div class="sv-load-more-wrap" id="sv-load-more-wrap">
      <p class="sv-progress-label" id="sv-progress-label">
        Showing
        <span id="sv-showing-count">12</span>
        of
        <span id="sv-total-count">{{ collections.all.products_count }}</span>
        items
      </p>
      <div class="sv-progress-bar">
        <div class="sv-progress-bar-fill" id="sv-progress-fill"></div>
      </div>
      <button class="sv-load-more-btn" id="sv-load-more-btn">LOAD MORE</button>
    </div>

  </div>
</section>

<script src="{{ 'collection.js' | asset_url }}" defer="defer"></script>

{% schema %}
  {
    "name": "t:general.collection",
    "settings": []
  }
{% endschema %}